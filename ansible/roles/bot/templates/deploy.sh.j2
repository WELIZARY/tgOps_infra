#!/bin/bash
# blue/green деплой бота на одной vm, вызывается из jenkins
set -euo pipefail

IMAGE="${1:?нужен образ}"
DIR=/opt/tgops
BLUE_PORT=18080
GREEN_PORT=18081
HEALTH_PATH=/healthz

cd "$DIR"

if grep -q ":$BLUE_PORT" Caddyfile; then
  ACTIVE=blue;  ACTIVE_PORT=$BLUE_PORT;  NEW=green; NEW_PORT=$GREEN_PORT
else
  ACTIVE=green; ACTIVE_PORT=$GREEN_PORT; NEW=blue;  NEW_PORT=$BLUE_PORT
fi
echo "активный $ACTIVE:$ACTIVE_PORT, поднимаю $NEW:$NEW_PORT"

# конфиг из secret manager в момент деплоя, в образ не зашит
gcloud secrets versions access latest --secret=tgops-telegram-token   > /tmp/tg_token
gcloud secrets versions access latest --secret=tgops-telegram-webhook-secret > /tmp/tg_wh

docker pull "$IMAGE"
docker rm -f "tgops-$NEW" 2>/dev/null || true
docker run -d --name "tgops-$NEW" --restart unless-stopped \
  -p 127.0.0.1:$NEW_PORT:8080 \
  -e TGOPS_TELEGRAM_TOKEN="$(cat /tmp/tg_token)" \
  -e TGOPS_TELEGRAM_WEBHOOK_SECRET="$(cat /tmp/tg_wh)" \
  -v /opt/tgops/config:/app/configs:ro \
  "$IMAGE"

for i in $(seq 1 20); do
  if curl -fsS "http://127.0.0.1:$NEW_PORT$HEALTH_PATH" >/dev/null; then ok=1; break; fi
  sleep 2
done
[ "${ok:-0}" = 1 ] || { echo "smoke не прошёл, откатываюсь..."; docker rm -f "tgops-$NEW"; exit 1; }


sed -i "s/:$ACTIVE_PORT/:$NEW_PORT/" Caddyfile
docker exec tgops-caddy caddy reload --config /etc/caddy/Caddyfile

echo "переключено на $NEW:$NEW_PORT, старый $ACTIVE гасим через 60с"
( sleep 60; docker rm -f "tgops-$ACTIVE" 2>/dev/null || true ) &
echo "$ACTIVE" > "$DIR/.previous_color"
rm -f /tmp/tg_token /tmp/tg_wh
