#!/bin/bash
# blue/green деплой бота на одной vm, вызывается из jenkins
# образ неизменяемый, конфиг (токен, секрет, host и пароль бд) подаётся через env
set -euo pipefail

IMAGE="${1:?нужен образ}"
DIR=/opt/tgops
BLUE_PORT=18080
GREEN_PORT=18081
HEALTH_PATH=/healthz

cd "$DIR"

if grep -q ":$BLUE_PORT" Caddyfile; then
  ACTIVE=blue;  ACTIVE_PORT=$BLUE_PORT;  NEW=green; NEW_PORT=$GREEN_PORT
else
  ACTIVE=green; ACTIVE_PORT=$GREEN_PORT; NEW=blue;  NEW_PORT=$BLUE_PORT
fi
echo "активный $ACTIVE:$ACTIVE_PORT, поднимаю $NEW:$NEW_PORT"

# секреты и параметры подключения из secret manager в момент деплоя
TG_TOKEN=$(gcloud secrets versions access latest --secret=tgops-telegram-token)
TG_WH=$(gcloud secrets versions access latest --secret=tgops-telegram-webhook-secret)
DB_HOST=$(gcloud secrets versions access latest --secret=tgops-db-host)
DB_PASS=$(gcloud secrets versions access latest --secret=tgops-db-password)

# приватный ключ, которым бот ходит на demo-ноды
gcloud secrets versions access latest --secret=tgops-bot-ssh-key > /opt/tgops/bot_ssh_key
chmod 0644 /opt/tgops/bot_ssh_key

docker pull "$IMAGE"
docker rm -f "tgops-$NEW" 2>/dev/null || true
docker run -d --name "tgops-$NEW" --restart unless-stopped \
  -p 127.0.0.1:$NEW_PORT:8080 \
  -v /opt/tgops/config.yaml:/app/config.yaml:ro \
  -v /opt/tgops/bot_ssh_key:/app/bot_ssh_key:ro \
  -v /opt/tgops/playbooks:/app/playbooks:ro \
  -e TGOPS_TELEGRAM_TOKEN="$TG_TOKEN" \
  -e TGOPS_TELEGRAM_WEBHOOK_SECRET="$TG_WH" \
  -e TGOPS_DATABASE_PRIMARY_HOST="$DB_HOST" \
  -e TGOPS_DATABASE_PRIMARY_PASSWORD="$DB_PASS" \
  "$IMAGE"

# образ generic - тулзы для /ansible run и cicd-вебхука и 0600-ключ ставим тут
# best-effort: если сети нет, бот всё равно живой, недоступен лишь /ansible run
docker exec -u 0 "tgops-$NEW" sh -c \
  'command -v ansible-playbook >/dev/null 2>&1 || apk add --no-cache openssh-client ansible-core curl' \
  >/dev/null 2>&1 || echo "провижн тулз не удался (без сети?), /ansible run будет недоступен"
docker exec -u 0 "tgops-$NEW" sh -c \
  'mkdir -p /home/tgops/.ssh && cp /app/bot_ssh_key /home/tgops/.ssh/ansible_key && chmod 600 /home/tgops/.ssh/ansible_key && chown -R tgops /home/tgops/.ssh' \
  2>/dev/null || true

for i in $(seq 1 30); do
  if curl -fsS "http://127.0.0.1:$NEW_PORT$HEALTH_PATH" >/dev/null; then ok=1; break; fi
  sleep 2
done
[ "${ok:-0}" = 1 ] || { echo "smoke не прошёл, смотри docker logs tgops-$NEW"; docker logs --tail 50 "tgops-$NEW" || true; docker rm -f "tgops-$NEW"; exit 1; }

sed -i "s/:$ACTIVE_PORT/:$NEW_PORT/" Caddyfile
docker restart tgops-caddy

echo "переключено на $NEW:$NEW_PORT, старый $ACTIVE гасим через 60с"
( sleep 60; docker rm -f "tgops-$ACTIVE" 2>/dev/null || true ) &
echo "$ACTIVE" > "$DIR/.previous_color"

# запоминаем образы для отката
if [ -f "$DIR/.current_image" ]; then
  cp "$DIR/.current_image" "$DIR/.previous_image"
fi
echo "$IMAGE" > "$DIR/.current_image"

# регистрация webhook url для бота
if curl -fsS "https://api.telegram.org/bot${TG_TOKEN}/setWebhook?url=https://bot.tgops.xyz/webhook/${TG_WH}&secret_token=${TG_WH}" >/dev/null; then
  echo "webhook у telegram зарегистрирован"
else
  echo "не удалось зарегистрировать webhook (проверь токен/сеть)"
fi
