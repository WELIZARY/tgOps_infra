# инвентарь для /ansible run, рендерит ansible, монтируется в /app/playbooks
# 0600 ключ ansible_key готовит deploy.sh при старте контейнера
[demo]
{% for h in groups.get('tag_demo', []) | sort %}
{{ h | regex_replace('^tgops-', '') }} ansible_host={{ hostvars[h].networkInterfaces[0].networkIP }}
{% endfor %}

[demo:vars]
ansible_user=tgops
ansible_ssh_private_key_file=/home/tgops/.ssh/ansible_key
ansible_ssh_common_args=-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null
ansible_python_interpreter=/usr/bin/python3
