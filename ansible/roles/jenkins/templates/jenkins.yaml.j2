# воспроизводит инстанс с нуля
jenkins:
  systemMessage: "tgops cd controller (jcasc)"
  numExecutors: 2
  securityRealm:
    local:
      allowsSignup: false
      users:
        - id: "{{ jenkins_admin_user | default('admin') }}"
          password: "{{ lookup('pipe', 'gcloud secrets versions access latest --secret=tgops-jenkins-admin-password') }}"
  authorizationStrategy:
    loggedInUsersCanDoAnything:
      allowAnonymousRead: false

unclassified:
  location:
    url: "https://jenkins.{{ primary_domain | default('tgops.xyz') }}/"

# пайплайны деплоя берём из репо tgOps_infra/pipelines
jobs:
  - script: |
      pipelineJob('deploy-bot') {
        parameters {
          stringParam('IMAGE_SHA', 'latest', 'git sha образа или latest')
          booleanParam('SKIP_APPROVAL', true, 'пропустить ручное подтверждение')
        }
        authenticationToken('{{ lookup("pipe", "gcloud secrets versions access latest --secret=tgops-jenkins-build-token") }}')
        definition {
          cpsScm {
            scm {
              git {
                remote { url('https://github.com/WELIZARY/tgOps_infra.git') }
                branch('main')
              }
            }
            scriptPath('pipelines/jenkins/Jenkinsfile.deploy-bot')
          }
        }
      }
  - script: |
      pipelineJob('rollback-bot') {
        definition {
          cpsScm {
            scm {
              git {
                remote { url('https://github.com/WELIZARY/tgOps_infra.git') }
                branch('main')
              }
            }
            scriptPath('pipelines/jenkins/Jenkinsfile.rollback-bot')
          }
        }
      }
