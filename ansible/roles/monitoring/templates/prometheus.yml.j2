global:
  scrape_interval: 30s

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

rule_files:
  - /etc/prometheus/rules.yml

# цели берём из инвентаря: node_exporter (:9100) на всех vm
{% set node_hosts = (groups.get('tag_bot', []) + groups.get('tag_jenkins', []) + groups.get('tag_monitoring', []) + groups.get('tag_demo', [])) | unique | sort %}
scrape_configs:
  - job_name: node
    static_configs:
{% for h in node_hosts %}
      - targets: ["{{ hostvars[h].networkInterfaces[0].networkIP }}:9100"]
        labels: { host: "{{ h | regex_replace('^tgops-', '') }}" }
{% endfor %}

  - job_name: blackbox-http
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - https://tgops.xyz
          - https://ocpp.by
          - https://bot.tgops.xyz/healthz
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox:9115
