groups:
  - name: tgops
    rules:
      - alert: InstanceDown
        expr: up{job="node"} == 0
        for: 1m
        labels: { severity: critical }
        annotations:
          summary: "нода {{ '{{' }} $labels.host {{ '}}' }} недоступна"

      - alert: HighNodeCPU
        expr: 100 - (avg by (host) (rate(node_cpu_seconds_total{mode="idle"}[2m])) * 100) > 85
        for: 2m
        labels: { severity: warning }
        annotations:
          summary: "высокая загрузка cpu на {{ '{{' }} $labels.host {{ '}}' }}"

      - alert: LowDiskSpace
        expr: (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 15
        for: 5m
        labels: { severity: warning }
        annotations:
          summary: "мало места на диске {{ '{{' }} $labels.host {{ '}}' }}"

      - alert: BlackboxProbeFailed
        expr: probe_success == 0
        for: 2m
        labels: { severity: critical }
        annotations:
          summary: "тест {{ '{{' }} $labels.instance {{ '}}' }} не проходит"
